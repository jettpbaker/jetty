{
  "$schema": "vscode://schemas/color-theme",
  "name": "VS Code 2026 Dark",
  "type": "dark",
  "colors": {
    "editor.foreground": "#BBBEBF",
    "editor.background": "#121314",
    "foreground": "#bfbfbf"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#8b949e"
      }
    },
    {
      "scope": [
        "comment.block.documentation",
        "comment.line.documentation"
      ],
      "settings": {
        "foreground": "#8b949e"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.cast",
        "keyword.operator.sizeof",
        "keyword.operator.logical.python",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ff7b72"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#d4d4d4"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#a5d6ff"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "string.escape"
      ],
      "settings": {
        "foreground": "#ff7b72"
      }
    },
    {
      "scope": [
        "string.regexp",
        "source.regexp",
        "string.regexp.character-class"
      ],
      "settings": {
        "foreground": "#a5d6ff"
      }
    },
    {
      "scope": [
        "string.other.link",
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#a5d6ff"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.binary"
      ],
      "settings": {
        "foreground": "#b5cea8"
      }
    },
    {
      "scope": [
        "constant",
        "constant.language",
        "constant.character",
        "entity.name.constant",
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#79c0ff"
      }
    },
    {
      "scope": [
        "constant.language.boolean",
        "constant.language.true",
        "constant.language.false"
      ],
      "settings": {
        "foreground": "#569cd6"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#d2a8ff"
      }
    },
    {
      "scope": [
        "entity.name.function.constructor",
        "entity.name.type.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#7ee787"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.namespace",
        "entity.other.inherited-class",
        "support.type",
        "support.class",
        "storage.type.primitive"
      ],
      "settings": {
        "foreground": "#4EC9B0"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#ffa657"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.super",
        "variable.parameter.function"
      ],
      "settings": {
        "foreground": "#79c0ff"
      }
    },
    {
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#ffa657"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.type.property-name",
        "meta.property-name",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#9cdcfe"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.id",
        "entity.other.attribute-name.class"
      ],
      "settings": {
        "foreground": "#9cdcfe"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#7ee787"
      }
    },
    {
      "scope": [
        "entity.name.label",
        "entity.name.section",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#ffa657"
      }
    },
    {
      "scope": [
        "entity.name.type.module"
      ],
      "settings": {
        "foreground": "#ffa657"
      }
    },
    {
      "scope": [
        "meta.preprocessor",
        "keyword.control.directive",
        "punctuation.definition.directive",
        "keyword.control.at-rule"
      ],
      "settings": {
        "foreground": "#569cd6"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.section"
      ],
      "settings": {
        "foreground": "#808080"
      }
    },
    {
      "scope": [
        "punctuation.definition.bracket",
        "meta.brace.round",
        "meta.brace.square",
        "meta.brace.curly",
        "punctuation.brackets"
      ],
      "settings": {
        "foreground": "#808080"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.delimiter"
      ],
      "settings": {
        "foreground": "#808080"
      }
    },
    {
      "scope": [
        "punctuation.definition.list",
        "markup.list"
      ],
      "settings": {
        "foreground": "#808080"
      }
    },
    {
      "scope": [
        "punctuation.special",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#808080"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#c9d1d9",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#c9d1d9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw"
      ],
      "settings": {
        "foreground": "#a5d6ff"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#a5d6ff"
      }
    },
    {
      "scope": [
        "meta.embedded",
        "source.embedded"
      ],
      "settings": {
        "foreground": "#D4D4D4"
      }
    },
    {
      "scope": [
        "keyword.control.at-rule",
        "meta.at-rule",
        "keyword.control.at-rule.css",
        "punctuation.definition.keyword.css"
      ],
      "settings": {
        "foreground": "#ff7b72"
      }
    },
    {
      "scope": [
        "support.type.property-name.css",
        "meta.property-name.css",
        "support.type.vendored.property-name"
      ],
      "settings": {
        "foreground": "#9cdcfe"
      }
    },
    {
      "scope": [
        "support.function",
        "support.function.css",
        "meta.function-call.css"
      ],
      "settings": {
        "foreground": "#d2a8ff"
      }
    },
    {
      "scope": [
        "keyword.other.unit",
        "keyword.other.unit.css"
      ],
      "settings": {
        "foreground": "#b5cea8"
      }
    },
    {
      "scope": [
        "keyword.other.keyframes",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.keyframe-offset.css",
        "entity.other.keyframe-offset.percentage.css"
      ],
      "settings": {
        "foreground": "#ff7b72"
      }
    }
  ]
}
