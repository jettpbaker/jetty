{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "react", "jsx-a11y", "import"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "unicorn/no-array-for-each": "error"
  },
  "env": {
    "browser": true,
    "node": true,
    "es2026": true
  },
  "ignorePatterns": ["dist/**"]
}
