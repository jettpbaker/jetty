{
  "name": "jetty",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "type": "module",
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsc --noEmit -p shared && tsc --noEmit -p server && tsc --noEmit -p client",
    "test": "bun test",
    "dev:server": "bun run --watch server/src/main.ts",
    "dev:client": "bun run --filter @jetty/client dev",
    "build": "bun run --filter @jetty/client build",
    "start": "bun run server/src/main.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "^7.0.2"
  }
}
